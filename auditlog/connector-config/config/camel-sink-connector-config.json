{
  "name": "vegetable-audit-sink-connector",
  "config": {
    "connector.class": "org.apache.camel.kafkaconnector.jdbc.CamelJdbcSinkConnector",
    "tasks.max": "1",
    "topics": "dbserver1.inventory.vegetable.enriched",
    "transforms": "insertPartition,insertOffset,insertTopic,jsonToSql",
    "transforms.insertPartition.type": "org.apache.kafka.connect.transforms.InsertField$Value",
    "transforms.insertPartition.partition.field": "kafkaPartition",
    "transforms.insertOffset.type": "org.apache.kafka.connect.transforms.InsertField$Value",
    "transforms.insertOffset.offset.field": "kafkaOffset",
    "transforms.insertTopic.type": "org.apache.kafka.connect.transforms.InsertField$Value",
    "transforms.insertTopic.topic.field": "kafkaTopic",
    "transforms.jsonToSql.type": "io.debezium.demos.auditing.custom.JsonToSqlTransform",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false",
    "camel.component.jdbc.dataSource": "#class:org.postgresql.ds.PGSimpleDataSource",
    "camel.component.jdbc.dataSource.serverName": "postgres-sink",
    "camel.component.jdbc.dataSource.portNumber": "5432",
    "camel.component.jdbc.dataSource.databaseName": "postgres",
    "camel.component.jdbc.dataSource.user": "postgresuser",
    "camel.component.jdbc.dataSource.password": "postgrespw",
    "camel.sink.path.dataSourceName": "default",
    "camel.idempotency.kafka.bootstrap.servers": "kafka:9092"
  }
}